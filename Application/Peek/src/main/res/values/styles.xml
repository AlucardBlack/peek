<resources>

    <!-- Material3 base. Deliberately Light (not DayNight) until the settings/home
         layouts stop hardcoding dark-on-light text colors; the in-app "dark theme"
         setting only drives the bubble/tab chrome, not these activities. -->
    <style name="AppThemeBase" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/color_primary</item>
        <item name="colorAccent">@color/color_accent</item>

        <item name="android:listSeparatorTextViewStyle">@style/ListSeparatorTextView</item>
    </style>

    <style name="AppTheme" parent="AppThemeBase"/>

    <!-- Applied as android:theme on the dark app-bar Toolbars. -->
    <style name="ToolbarTheme" parent="ThemeOverlay.Material3.Dark">
        <item name="colorPrimary">@color/color_primary</item>
        <item name="titleMarginStart">16dp</item>
    </style>


    <style name="ListSeparatorTextView">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">32dp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/color_primary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingLeft">8dp</item>
    </style>

    <!-- Material3 parent (was android:Theme.Holo.Light) so AppCompatActivity consumers
         (EntryActivity) don't crash; plain-Activity consumers (the Notification*Activity
         redirect shims) work fine with any theme regardless. -->
    <style name="TransparentTheme" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>

    <style name="ToolbarButton">
        <item name="android:layout_width">@dimen/toolbar_height</item>
        <item name="android:layout_height">@dimen/toolbar_height</item>
        <item name="android:layout_gravity">center_vertical</item>
    </style>

    <!-- Merged from the old values-v21 overrides (always active at minSdk 26). -->
    <style name="MainServiceThemeLight" parent="@android:style/Theme.Material.Light">
        <item name="android:popupMenuStyle">@style/popupMenuStyleLight</item>
    </style>

    <style name="MainServiceThemeDark" parent="@android:style/Theme.Material">
        <item name="android:popupMenuStyle">@style/popupMenuStyleDark</item>
    </style>

    <style name="popupMenuStyleLight" parent="@android:style/Widget.PopupMenu">
        <item name="android:popupBackground">@drawable/dropdown_background_light</item>
    </style>

    <style name="popupMenuStyleDark" parent="@android:style/Widget.PopupMenu">
        <item name="android:popupBackground">@drawable/dropdown_background_dark</item>
    </style>

    <!-- Applied via style= on a plain LinearLayout (view_section_header.xml), not as an
         android:theme, so a Theme parent was never actually consulted - only the explicit
         background item below ever applied. -->
    <style name="SectionHeaderTheme">
        <item name="android:background">#f5f5f5</item>
    </style>

    <!-- Was a raw Button with a hand-drawn selector background + a separate hardcoded-size
         shadow View as a sibling; now a real Material3 filled button, ripple/elevation/state
         handled by the framework. android:background/textColor deliberately unset - inherited
         from Widget.Material3.Button (colorPrimary fill, colorOnPrimary text). -->
    <style name="ActionButton" parent="Widget.Material3.Button">
        <item name="android:layout_width">200dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Prompt">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_gravity">bottom</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:background">#323232</item>
        <item name="android:clickable">true</item>
    </style>

    <style name="PromptMessage">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_gravity">center_vertical</item>
        <item name="android:textAppearance">?android:textAppearanceSmall</item>
        <item name="android:textColor">#fff</item>
        <item name="android:paddingLeft">16dp</item>
        <item name="android:paddingRight">16dp</item>
    </style>

    <style name="PromptButtonTextView">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:textColor">@color/color_primary_bright</item>
        <item name="android:paddingRight">16dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="AcceptTermsText">
        <item name="android:layout_width">wrap_content</item>
    </style>


    <!-- Material3 NoActionBar parent (was android:Theme.Holo.Light + a manual
         android:actionBarStyle/windowActionBarOverlay) so ExpandedActivity can become an
         AppCompatActivity. The old native action bar was hidden immediately in onCreate() and
         never shown again, so it's dropped outright rather than ported to a support Toolbar. -->
    <style name="ExpandedModeBaseTheme" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">false</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:colorBackgroundCacheHint">@null</item>
    </style>

    <style name="ExpandedModeTheme" parent="ExpandedModeBaseTheme"/>


</resources>
